/// Test interface
interface Test {
	quit()

	ping() -> ()

	echo(input: TestEnum) -> (output: TestEnum)

	echo_ref(input: Ref<Test>) -> (output: Ref<Test>)
}

/// test struct
struct TestStructClone {
	string: String,
	id: u64,
	binder_ref: Ref<Test>,
}

/// Test enum
enum TestEnum {
	TestStruct {
		test_struct: TestStruct,
	},
	Fd {
		fd: Fd,
	},
	EmptyVariant
}
