/// Test interface
interface Test {
	quit()

	ping() -> ()

	echo(input: String) -> (output: String)

	echo_ref(input: Ref<Test2>) -> (output: Ref<Test2>)
}

/// test struct
struct TestStructClone {
	string: String,
	id: u64,
	binder_ref: Ref<Test>,
}

/// Test enum
enum TestEnum {
	StringVariant {
		string: String,
	},
	Fd {
		fd: Fd,
	},
	EmptyVairant
}

/// Test2 interface
interface Test2 {
	quit()

	ping() -> ()

	echo(input: String) -> (output: String)

	echo_ref(input: Ref) -> (output: Ref)
}
