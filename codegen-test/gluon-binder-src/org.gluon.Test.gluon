import "org.gluon.Types.gluon" as types

/// Test interface
interface Test {
	quit()

	ping() -> ()

	echo(input: TestEnum) -> (output: TestEnum)

	echo_ref(input: Ref<Test>) -> (output: Ref<Test>)

	get_position() -> (position: types::Vec3)
}

/// test struct
struct TestStruct {
	string: String,
	id: u64,
	binder_ref: Ref<Test>,
	position: types::Vec3,
}

/// Test enum
enum TestEnum {
	TestStruct {
		test_struct: TestStruct,
	},
	Fd {
		fd: Fd,
	},
	EmptyVariant
}
